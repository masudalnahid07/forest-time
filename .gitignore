.ipynb_checkpoints/

# pyenv
.python-version

# celery
celerybeat-schedule.*

# mypy
.mypy_cache/

# Documentation
/site

# Backup
*.bak

# Misc
*.pot
*.iws
out/
atlassian-ide-plugin.xml

